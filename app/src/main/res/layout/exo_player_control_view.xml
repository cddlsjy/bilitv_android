<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@color/black_overlay"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 进度条 -->
    <androidx.media3.ui.DefaultTimeBar
        android:id="@id/exo_progress"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        app:played_color="@color/bili_pink"
        app:unplayed_color="@color/text_hint"
        app:buffered_color="@color/text_secondary" />

    <!-- 时间显示 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@id/exo_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" / "
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@id/exo_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 播放/暂停按钮 -->
        <ImageButton
            android:id="@id/exo_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="播放/暂停"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@id/exo_rew"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="快退10秒"
            android:scaleType="centerInside"
            android:src="@drawable/ic_rewind" />

        <ImageButton
            android:id="@id/exo_ffwd"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="快进10秒"
            android:scaleType="centerInside"
            android:src="@drawable/ic_forward" />

    </LinearLayout>

</LinearLayout>